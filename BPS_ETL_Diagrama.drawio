        </mxCell>

        <mxCell id="paso3_bg" value="&lt;b style='font-size:12px;color:#375623'&gt;PASO 3 — fact_ejecuciones&lt;/b&gt;&lt;br&gt;&lt;i style='font-size:9px;color:#666'&gt;core/etl/paso3_fact_ejecuciones.py&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;align=left;spacingLeft=8;spacingTop=6;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="1064" width="1840" height="390" as="geometry" />
        </mxCell>

        <!-- Paso 3: mapeo proceso herramienta -->
        <mxCell id="p3_r1" value="&lt;b style='color:#7d4b00'&gt;Regla 1 — Mapeo proceso DB_Server → herramienta canónica&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Diccionario PROCESO_A_HERRAMIENTA (config/settings.py): 39 procesos → 26 herramientas&lt;br&gt;&lt;table style='font-size:10px;width:100%'&gt;&lt;tr&gt;&lt;td style='color:#555'&gt;&quot;GUI: Control Correlatividad&quot; / &quot;GUI: Controlar correlatividad&quot; / &quot;AFIP voucher correlativity control&quot;&lt;/td&gt;&lt;td&gt;→&lt;/td&gt;&lt;td style='color:#1F4E79'&gt;&quot;Control de correlatividad - ComplyPro&quot;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='color:#555'&gt;&quot;GUI: Identificación Duplicados&quot; / &quot;GUI: Detección de duplicados&quot; (2 variantes)&lt;/td&gt;&lt;td&gt;→&lt;/td&gt;&lt;td style='color:#1F4E79'&gt;&quot;Control de duplicados - ComplyPro&quot;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='color:#555'&gt;&quot;Tracking de Vencimientos&quot;&lt;/td&gt;&lt;td&gt;→&lt;/td&gt;&lt;td style='color:#1F4E79'&gt;&quot;Calendarios Impositivos&quot;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style='color:#555'&gt;Procesos sin herramienta en Relevamiento (WP-Ganancias, Tablas Ratio, etc.)&lt;/td&gt;&lt;td&gt;→&lt;/td&gt;&lt;td style='color:#9673a6'&gt;se incluyen con nombre original · flag en_relevamiento=False&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/span&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;"
          vertex="1" parent="1">
          <mxGeometry x="50" y="1114" width="880" height="160" as="geometry" />
        </mxCell>

        <!-- Paso 3: normalizacion estados -->
        <mxCell id="p3_r2" value="&lt;b style='color:#375623'&gt;Regla 2 — Normalización de estados&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;&lt;b style='color:green'&gt;Correcto&lt;/b&gt;: &quot;Correcto&quot;, &quot;Finalizado&quot;&lt;br&gt;&lt;b style='color:#c00'&gt;Erroneo&lt;/b&gt;: &quot;Erróneo&quot;, &quot;Proceso terminado/finalizado con errores&quot;, &quot;0&quot;&lt;br&gt;&lt;b style='color:#cc6600'&gt;Con Observaciones&lt;/b&gt;: &quot;Finalizado con observaciones&quot;, &quot;Proceso terminado/finalizado con observaciones&quot;&lt;br&gt;&lt;b style='color:#555'&gt;Correo no enviado&lt;/b&gt;: &quot;Correo no enviado&quot;&lt;/span&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF3FB;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;"
          vertex="1" parent="1">
          <mxGeometry x="950" y="1114" width="480" height="160" as="geometry" />
        </mxCell>

        <!-- Paso 3: join dim_clientes -->
        <mxCell id="p3_r3" value="&lt;b style='color:#375623'&gt;Regla 3 — Join con dim_clientes por CUIT&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;df_db[cuit_cliente] → dim_clientes[cuit] (left join)&lt;br&gt;Trae: nombre_cliente_canonico + gerente_responsable&lt;br&gt;Si no tiene CUIT (tipo VACIO o NOMBRE sin resolución):&lt;br&gt;nombre_cliente_canonico = cliente_nombre (texto libre tal cual)&lt;/span&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF3FB;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=10;"
          vertex="1" parent="1">
          <mxGeometry x="1450" y="1114" width="390" height="160" as="geometry" />
        </mxCell>

        <!-- Paso 3: columnas resultado -->
        <mxCell id="p3_result" value="&lt;b style='font-size:11px;color:#375623'&gt;Columnas resultantes de fact_ejecuciones (30.881 filas)&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;id · username · &lt;b&gt;proceso_original&lt;/b&gt; · &lt;b&gt;herramienta&lt;/b&gt; · &lt;b&gt;en_relevamiento&lt;/b&gt; (bool) · estado · &lt;b&gt;estado_normalizado&lt;/b&gt; · iniciado · finalizado · &lt;b&gt;duracion_segundos&lt;/b&gt; · tipo_cliente · cuit_cliente · &lt;b&gt;nombre_cliente_canonico&lt;/b&gt; · gerente_responsable · items_count · observaciones · anio · mes · semana&lt;/span&gt;"
